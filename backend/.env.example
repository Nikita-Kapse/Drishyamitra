# ─── Groq LLM ─────────────────────────────────────────────────────────────────
GROQ_API_KEY=

# ─── Gmail (for photo delivery) ───────────────────────────────────────────────
GMAIL_USER=
GMAIL_APP_PASSWORD=

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///drishyamitra.db

# ─── Flask ────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
FLASK_DEBUG=true

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000

# ─── Upload ───────────────────────────────────────────────────────────────────
UPLOAD_FOLDER=uploads

# ─── Public API Base URL (used for photo URLs in WhatsApp, chatbot, etc.) ─────
# Set this to your deployed backend URL, e.g. https://api.yourdomain.com/api
API_BASE_URL=
